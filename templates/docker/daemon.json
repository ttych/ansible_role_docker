{
    "userns-remap": "{{ docker_userns_remap }}",
    "storage-driver": "{{ docker_storage_driver }}",
{% if docker_firewall == 'nftables' %}
    "iptables": true,
    "experimental": true,
    "daemon": {
        "iptables": true
    },
{% else %}
    "iptables": true,
{% endif %}
    "log-driver": "json-file",
    "log-opts": {
        "max-size": "{{ docker_log_max_size }}",
        "max-file": "{{ docker_log_max_file }}"
    }
}
